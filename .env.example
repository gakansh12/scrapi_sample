# Required
GCP_PROJECT_ID=
GCP_LOCATION=global

# The CXAS App display name (human readable) to run the session against.
CXAS_APP_NAME=

# Optional: if provided, we will verify this agent exists in the app.
CXAS_AGENT_DISPLAY_NAME=

# Optional: set if you want to explicitly use a service account JSON key.
# If omitted, cxas-scrapi will use gcloud Application Default Credentials.
GOOGLE_APPLICATION_CREDENTIALS=
